<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/widget_root"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@drawable/taxometer_widget_background"
  android:padding="15dp">

  <LinearLayout
    android:id="@+id/widget_active_content"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:gravity="center_vertical"
      android:orientation="horizontal">
      <ImageView
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:contentDescription="@string/taxometer_trip_widget_name"
        android:src="@drawable/taxometer_widget_car" />
      <TextView
        android:id="@+id/widget_status"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_weight="1"
        android:ellipsize="end"
        android:fontFamily="sans-serif-medium"
        android:gravity="end"
        android:maxLines="1"
        android:text="Active"
        android:textColor="#38C989"
        android:textSize="11sp" />
    </LinearLayout>

    <TextView
      android:id="@+id/widget_amount"
      android:layout_width="match_parent"
      android:layout_height="0dp"
      android:layout_weight="1"
      android:ellipsize="end"
      android:fontFamily="sans-serif-black"
      android:gravity="bottom|start"
      android:maxLines="1"
      android:text="PLN 28.40"
      android:textColor="#F7F7F7"
      android:textSize="27sp" />

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="6dp"
      android:gravity="center_vertical"
      android:orientation="horizontal">
      <Chronometer
        android:id="@+id/widget_time"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:fontFamily="sans-serif-medium"
        android:maxLines="1"
        android:textColor="#F7F7F7"
        android:textSize="12sp" />
      <TextView
        android:id="@+id/widget_distance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:fontFamily="sans-serif-medium"
        android:maxLines="1"
        android:text="3.8 km"
        android:textColor="#F7F7F7"
        android:textSize="12sp" />
    </LinearLayout>
  </LinearLayout>

  <LinearLayout
    android:id="@+id/widget_idle_content"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="start"
    android:orientation="vertical"
    android:visibility="gone">
    <ImageView
      android:layout_width="32dp"
      android:layout_height="32dp"
      android:contentDescription="@string/taxometer_trip_widget_name"
      android:src="@drawable/taxometer_widget_car" />
    <TextView
      android:id="@+id/widget_idle_app_name"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="10dp"
      android:fontFamily="sans-serif-medium"
      android:maxLines="1"
      android:text="Taxometer"
      android:textColor="#FFCC00"
      android:textSize="11sp" />
    <TextView
      android:id="@+id/widget_idle_title"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="3dp"
      android:ellipsize="end"
      android:fontFamily="sans-serif-black"
      android:maxLines="2"
      android:text="Ready for a new trip"
      android:textColor="#F7F7F7"
      android:textSize="16sp" />
    <TextView
      android:id="@+id/widget_idle_hint"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="3dp"
      android:ellipsize="end"
      android:maxLines="2"
      android:text="Open the app to start"
      android:textColor="#A9ADB4"
      android:textSize="10sp" />
  </LinearLayout>
</FrameLayout>
